# Optional: canonical site URL for metadata (OpenGraph, sitemap).
# Vercel auto-sets VERCEL_URL; use this for custom domain or local preview.
NEXT_PUBLIC_SITE_URL=https://www.henry-vfx.com/

# Optional: local-only key for generating UI/UX visual assets with OpenRouter.
# Put the real value in .env.local, never commit it.
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=openai/gpt-5-image
OPENROUTER_APP_URL=https://www.henry-vfx.com/
OPENROUTER_APP_NAME=Henry VFX Portfolio
